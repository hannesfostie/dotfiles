# Unix
alias tlf="tail -f"
alias ln='ln -v'
alias mkdir='mkdir -p'
alias ...='../..'
alias l='ls'
alias ll='ls -al'
alias lh='ls -Alh'
alias -g G='| grep'
alias -g M='| less'
alias -g L='| wc -l'
alias -g ONE="| awk '{ print \$1}'"
alias e="$EDITOR"
alias v="$VISUAL"

# Bundler
alias b="bundle"

# Rails
alias migrate="rake db:migrate db:rollback && rake db:migrate"
alias m="migrate"
alias rk="rake"
alias s="rspec"

# Git
alias g="git"
alias ga="git add"
alias gb="git branch"
alias gc="git commit"
alias gp="git push"
alias gl="git pull"
alias gap="ga -p"
alias gba="gb -a"
alias gco="git checkout"
alias gcp="gc -p"
alias gst="git status"

# Include custom aliases
[[ -f ~/.aliases.local ]] && source ~/.aliases.local
