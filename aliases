# Unix
alias tlf="tail -f"
alias ln='ln -v'
alias mkdir='mkdir -p'
alias ...='../..'
alias less='less -R'
alias l='ls'
alias ll='ls -al'
alias lh='ls -Alh'
alias -g G='| grep'
alias -g M='| less'
alias -g L='| wc -l'
alias -g ONE="| awk '{ print \$1}'"
alias e="$EDITOR"
alias v="$VISUAL"

# Bundler
alias b="bundle"

# Rails
alias migrate="rake db:migrate db:rollback && rake db:migrate"
alias m="migrate"
alias rk="rake"
alias s="rspec"

# Git
alias g="git"
alias ga="git add"
alias gb="git branch"
alias gc="git commit -v"
alias gd="git diff"
alias gca="gc -a"
alias gp="git push"
alias gl="git pull --rebase"
alias gap="ga -p"
alias gba="gb -a"
alias gco="git checkout"
alias gcp="gc -p"
alias gst="git status"

# Heroku
alias h="heroku"
alias hr="h run"
alias hrc="hr console"
alias hl="h local"
alias hlw="hl web"

alias lock='/System/Library/CoreServices/"Menu Extras"/User.menu/Contents/Resources/CGSession -suspend'

# Include custom aliases
[[ -f ~/.aliases.local ]] && source ~/.aliases.local
